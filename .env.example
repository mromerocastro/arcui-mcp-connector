# ArcUI Unity bridge
ARCUI_BRIDGE_URL=http://localhost:17842
ARCUI_BRIDGE_TOKEN=
ARCUI_BRIDGE_TIMEOUT_MS=5000

# Connector refuses to start if ARCUI_BRIDGE_URL points at a non-loopback host
# over plain http:// (the bearer token would travel in cleartext). Set this to
# 'true' ONLY on a trusted private link such as a VPN tunnel where TLS is
# terminated at the network layer. Default: false.
ARCUI_BRIDGE_ALLOW_INSECURE=false

# Gemini File Search / ArcUI Knowledge Pack
# Disabled by default. Enable only when this process is allowed to send
# selected project documents, prompts, scenarios, and debrief data to Gemini.
GEMINI_API_KEY=
ARCUI_ENABLE_KNOWLEDGE_TOOLS=false
ARCUI_KNOWLEDGE_STORE=fileSearchStores/your-store-id
ARCUI_KNOWLEDGE_MODEL=gemini-2.5-flash
ARCUI_KNOWLEDGE_EMBEDDING_MODEL=models/gemini-embedding-2

# File indexing is separately gated and restricted to approved roots.
ARCUI_ENABLE_KNOWLEDGE_INDEXING=false
ARCUI_KNOWLEDGE_ROOTS=C:/ArcUI/approved-docs;C:/ArcUI/context-packs
